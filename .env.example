# ─── PORA Website Environment Variables ───────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to git.

# API
NEXT_PUBLIC_API_URL=https://api.pora.xyz/v1

# Chain / RPC (for wallet connection)
NEXT_PUBLIC_CHAIN_ID=1
NEXT_PUBLIC_RPC_URL=https://mainnet.infura.io/v3/YOUR_KEY

# WalletConnect project ID (optional)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# PoRa Explorer — ngrok tunnel URL (no trailing slash)
# Example: NEXT_PUBLIC_EXPLORER_API=https://abc123.ngrok.io
NEXT_PUBLIC_EXPLORER_API=https://YOUR_NGROK_URL
